<!-- HeroBanner.razor — Carrusel con imágenes reales de Respawn Shop -->
@implements IDisposable

<section class="hero-section" id="hero-banner" aria-label="Banners Respawn Shop">
    <div class="hero-carousel">

        <!-- Slides del carrusel -->
        @for (int i = 0; i < banners.Count; i++)
        {
            var idx = i;
            var banner = banners[i];
            <div class="hero-slide @(activeSlide == idx ? "active" : "")" id="hero-slide-@idx">
                <a href="@banner.Link" class="banner-link">
                    <img src="@banner.ImageUrl"
                         alt="@banner.Alt"
                         class="banner-img"
                         loading="@(idx == 0 ? "eager" : "lazy")" />
                </a>
            </div>
        }

        <!-- Indicadores de slide -->
        <div class="hero-indicators" id="hero-indicators">
            @for (int i = 0; i < banners.Count; i++)
            {
                var idx = i;
                <button class="hero-dot @(activeSlide == idx ? "active" : "")"
                        id="hero-dot-@idx"
                        aria-label="Banner @(idx + 1)"
                        @onclick="() => GoToSlide(idx)">
                </button>
            }
        </div>

        <!-- Botones prev/next -->
        <button class="hero-arrow hero-arrow-prev" id="hero-prev" aria-label="Anterior" @onclick="PrevSlide">
            ‹
        </button>
        <button class="hero-arrow hero-arrow-next" id="hero-next" aria-label="Siguiente" @onclick="NextSlide">
            ›
        </button>

    </div>
</section>

@code {
    private int activeSlide = 0;
    private System.Threading.Timer? carouselTimer;

    private readonly List<BannerSlide> banners = new()
    {
        new BannerSlide
        {
            ImageUrl  = "images/banner1.png",
            Alt       = "Respawn Shop — Tu destino gamer online. Videojuegos, consolas y accesorios.",
            Link      = "/catalogo"
        },
        new BannerSlide
        {
            ImageUrl  = "images/banner2.png",
            Alt       = "Respawn Shop — Consolas, periféricos y accesorios gaming de última generación.",
            Link      = "/catalogo"
        }
    };

    protected override void OnInitialized()
    {
        carouselTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() => { NextSlide(); StateHasChanged(); }),
            state: null,
            dueTime: 5000,
            period: 5000
        );
    }

    private void PrevSlide()
    {
        activeSlide = (activeSlide - 1 + banners.Count) % banners.Count;
        ResetTimer();
    }

    private void NextSlide()
    {
        activeSlide = (activeSlide + 1) % banners.Count;
    }

    private void GoToSlide(int index)
    {
        activeSlide = index;
        ResetTimer();
    }

    private void ResetTimer()
    {
        carouselTimer?.Change(5000, 5000);
    }

    public void Dispose()
    {
        carouselTimer?.Dispose();
    }

    private record BannerSlide
    {
        public string ImageUrl { get; init; } = string.Empty;
        public string Alt      { get; init; } = string.Empty;
        public string Link     { get; init; } = "/";
    }
}

<style>
    /* ── Sección hero ─────────────────────────────────────── */
    .hero-section {
        position: relative;
        overflow: hidden;
        background: #000;
        width: 100%;
    }

    /* ── Carrusel ─────────────────────────────────────────── */
    .hero-carousel {
        position: relative;
        width: 100%;
        aspect-ratio: 1024 / 275;   /* ratio del banner */
        min-height: 160px;
        overflow: hidden;
    }

    /* ── Slides ───────────────────────────────────────────── */
    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.8s ease;
        display: flex;
    }

    .hero-slide.active {
        opacity: 1;
        position: relative;
    }

    .banner-link {
        display: block;
        width: 100%;
        height: 100%;
        line-height: 0;
    }

    .banner-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transition: transform 0.6s ease;
    }

    .hero-slide.active .banner-img:hover {
        transform: scale(1.01);
    }

    /* ── Indicadores ──────────────────────────────────────── */
    .hero-indicators {
        position: absolute;
        bottom: 14px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 8px;
        z-index: 10;
    }

    .hero-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.4);
        border: 2px solid rgba(255, 255, 255, 0.6);
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 0;
    }

    .hero-dot.active {
        background: #fff;
        width: 28px;
        border-radius: 999px;
        box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
    }

    /* ── Flechas prev / next ──────────────────────────────── */
    .hero-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        background: rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #fff;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        font-size: 26px;
        line-height: 1;
        cursor: pointer;
        transition: background 0.25s ease, transform 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(6px);
    }

    .hero-arrow:hover {
        background: rgba(0, 0, 0, 0.75);
        transform: translateY(-50%) scale(1.1);
    }

    .hero-arrow-prev { left: 16px; }
    .hero-arrow-next { right: 16px; }

    /* ── Responsive ───────────────────────────────────────── */
    @@media (max-width: 768px) {
        .hero-carousel { aspect-ratio: 16 / 7; }
        .hero-arrow { width: 34px; height: 34px; font-size: 20px; }
    }

    @@media (max-width: 480px) {
        .hero-carousel { aspect-ratio: 16 / 9; }
        .hero-arrow { display: none; }
    }
</style>
