@using Blazor_Respawn_Shop.Models

<!-- FilterSidebar.razor — Panel de filtros lateral del catálogo -->
<!-- Usa EventCallback para notificar al padre (Catalogo.razor) de cada cambio de filtro -->

<aside class="filter-sidebar" id="filter-sidebar" aria-label="Filtros del catálogo">

    <!-- Encabezado -->
    <div class="filter-header">
        <h3 class="filter-title">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"/>
            </svg>
            Filtros
        </h3>
        @if (HayFiltrosActivos)
        {
            <button class="filter-clear-btn" id="btn-clear-filters" @onclick="LimpiarFiltros">
                Limpiar todo
            </button>
        }
    </div>

    <!-- Filtro: Categoría -->
    <div class="filter-group" id="filter-group-categoria">
        <h4 class="filter-group-title">Categoría</h4>
        <div class="filter-options">
            @foreach (var cat in categorias)
            {
                <label class="filter-option" id="filter-cat-@cat.ToLower().Replace(" ", "-")">
                    <input type="radio"
                           name="categoria"
                           value="@cat"
                           checked="@(CategoriaSeleccionada == cat)"
                           @onchange="() => CambiarCategoria(cat)" />
                    <span class="filter-option-check"></span>
                    <span class="filter-option-label">@cat</span>
                    @if (cat != "Todos")
                    {
                        <span class="filter-option-emoji">@GetEmoji(cat)</span>
                    }
                </label>
            }
        </div>
    </div>

    <!-- Filtro: Solo en stock -->
    <div class="filter-group" id="filter-group-stock">
        <h4 class="filter-group-title">Disponibilidad</h4>
        <label class="filter-toggle" id="filter-solo-en-stock">
            <span class="filter-toggle-label">Solo en stock</span>
            <div class="toggle-switch @(SoloEnStock ? "active" : "")"
                 @onclick="ToggleSoloEnStock"
                 role="switch"
                 aria-checked="@SoloEnStock">
                <span class="toggle-knob"></span>
            </div>
        </label>
    </div>

    <!-- Filtro: Solo digital / físico -->
    <div class="filter-group" id="filter-group-tipo">
        <h4 class="filter-group-title">Tipo de producto</h4>
        <div class="filter-options">
            @foreach (var tipo in tipos)
            {
                <label class="filter-option" id="filter-tipo-@tipo.Key.ToLower()">
                    <input type="radio"
                           name="tipo"
                           value="@tipo.Key"
                           checked="@(TipoSeleccionado == tipo.Key)"
                           @onchange="() => CambiarTipo(tipo.Key)" />
                    <span class="filter-option-check"></span>
                    <span class="filter-option-label">@tipo.Value</span>
                </label>
            }
        </div>
    </div>

    <!-- Filtro: Rango de precio -->
    <div class="filter-group" id="filter-group-precio">
        <h4 class="filter-group-title">
            Precio máximo: <span class="filter-price-value">$ @PrecioMax</span>
        </h4>
        <input type="range"
               class="filter-slider"
               min="0"
               max="1000"
               step="10"
               value="@PrecioMax"
               @oninput="OnPrecioMaxChange"
               id="slider-precio-max"
               aria-label="Precio máximo" />
        <div class="filter-slider-labels">
            <span>$ 0</span>
            <span>$ 1000</span>
        </div>
    </div>

</aside>

@code {
    // [Parameter] — Estado de los filtros recibido del padre (Catalogo.razor)
    [Parameter] public string CategoriaSeleccionada { get; set; } = "Todos";
    [Parameter] public bool SoloEnStock { get; set; } = false;
    [Parameter] public string TipoSeleccionado { get; set; } = "Todos";
    [Parameter] public int PrecioMax { get; set; } = 1000;

    // EventCallbacks para notificar al padre de cada cambio de filtro
    [Parameter] public EventCallback<string> OnCategoriaChanged { get; set; }
    [Parameter] public EventCallback<bool> OnSoloEnStockChanged { get; set; }
    [Parameter] public EventCallback<string> OnTipoChanged { get; set; }
    [Parameter] public EventCallback<int> OnPrecioMaxChanged { get; set; }

    // Opciones de filtros
    private readonly List<string> categorias = new() { "Todos", "Juegos", "Consolas", "Controles", "FunkoPops", "Accesorios" };
    private readonly Dictionary<string, string> tipos = new()
    {
        { "Todos", "Todos" },
        { "Digital", "🌐 Digital" },
        { "Fisico", "📦 Físico" }
    };

    /// <summary>Verifica si hay algún filtro activo.</summary>
    private bool HayFiltrosActivos =>
        CategoriaSeleccionada != "Todos" || SoloEnStock || TipoSeleccionado != "Todos" || PrecioMax < 1000;

    /// <summary>Notifica al padre cuando cambia la categoría.</summary>
    private async Task CambiarCategoria(string cat)
    {
        await OnCategoriaChanged.InvokeAsync(cat);
    }

    /// <summary>Notifica al padre cuando se activa/desactiva el toggle de stock.</summary>
    private async Task ToggleSoloEnStock()
    {
        await OnSoloEnStockChanged.InvokeAsync(!SoloEnStock);
    }

    /// <summary>Notifica al padre cuando cambia el tipo de producto.</summary>
    private async Task CambiarTipo(string tipo)
    {
        await OnTipoChanged.InvokeAsync(tipo);
    }

    /// <summary>Notifica al padre cuando cambia el precio máximo (slider).</summary>
    private async Task OnPrecioMaxChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int valor))
        {
            await OnPrecioMaxChanged.InvokeAsync(valor);
        }
    }

    /// <summary>Limpia todos los filtros notificando al padre.</summary>
    private async Task LimpiarFiltros()
    {
        await OnCategoriaChanged.InvokeAsync("Todos");
        await OnSoloEnStockChanged.InvokeAsync(false);
        await OnTipoChanged.InvokeAsync("Todos");
        await OnPrecioMaxChanged.InvokeAsync(1000);
    }

    private static string GetEmoji(string cat) => cat switch
    {
        "Juegos" => "💿",
        "Consolas" => "🕹️",
        "Controles" => "🎯",
        "FunkoPops" => "🧸",
        "Accesorios" => "🎧",
        _ => "📦"
    };
}

<style>
    .filter-sidebar {
        background: var(--bg-secondary); border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg); padding: var(--space-6); position: sticky; top: 90px;
        height: fit-content;
    }
    .filter-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6); }
    .filter-title {
        display: flex; align-items: center; gap: var(--space-2);
        font-size: var(--font-size-base); font-weight: 700; color: var(--text-primary);
    }
    .filter-clear-btn {
        background: none; border: none; color: var(--accent);
        font-size: var(--font-size-xs); cursor: pointer; font-family: var(--font-base);
        padding: 2px var(--space-2); border-radius: var(--radius-sm);
        transition: background var(--transition-fast);
    }
    .filter-clear-btn:hover { background: var(--accent-glow); }
    .filter-group { margin-bottom: var(--space-6); padding-bottom: var(--space-6); border-bottom: 1px solid var(--border-subtle); }
    .filter-group:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .filter-group-title { font-size: var(--font-size-sm); font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: var(--space-4); }
    .filter-options { display: flex; flex-direction: column; gap: var(--space-2); }
    .filter-option { display: flex; align-items: center; gap: var(--space-3); cursor: pointer; padding: var(--space-2) var(--space-3); border-radius: var(--radius-md); transition: background var(--transition-fast); }
    .filter-option:hover { background: var(--bg-hover); }
    .filter-option input[type="radio"] { display: none; }
    .filter-option-check {
        width: 16px; height: 16px; border-radius: 50%;
        border: 2px solid var(--text-muted); flex-shrink: 0; transition: all var(--transition-fast);
        display: flex; align-items: center; justify-content: center;
    }
    .filter-option input:checked ~ .filter-option-check { border-color: var(--accent); background: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
    .filter-option input:checked ~ .filter-option-check::after { content: ''; width: 6px; height: 6px; border-radius: 50%; background: white; }
    .filter-option-label { font-size: var(--font-size-sm); color: var(--text-secondary); flex: 1; transition: color var(--transition-fast); }
    .filter-option input:checked ~ .filter-option-check ~ .filter-option-label { color: var(--text-primary); font-weight: 600; }
    .filter-option-emoji { font-size: var(--font-size-sm); }
    /* Toggle */
    .filter-toggle { display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
    .filter-toggle-label { font-size: var(--font-size-sm); color: var(--text-secondary); }
    .toggle-switch {
        width: 44px; height: 24px; background: var(--bg-hover); border: 1px solid var(--border-subtle);
        border-radius: var(--radius-full); position: relative; transition: all var(--transition-base); cursor: pointer;
    }
    .toggle-switch.active { background: var(--accent); border-color: var(--accent); box-shadow: 0 0 10px var(--accent-glow); }
    .toggle-knob {
        position: absolute; top: 2px; left: 2px;
        width: 18px; height: 18px; background: white; border-radius: 50%;
        transition: transform var(--transition-base); box-shadow: 0 1px 4px rgba(0,0,0,0.3);
    }
    .toggle-switch.active .toggle-knob { transform: translateX(20px); }
    /* Slider */
    .filter-slider {
        width: 100%; -webkit-appearance: none; appearance: none;
        height: 4px; border-radius: var(--radius-full);
        background: linear-gradient(to right, var(--accent) 0%, var(--bg-hover) 0%);
        outline: none; cursor: pointer; margin-bottom: var(--space-2);
    }
    .filter-slider::-webkit-slider-thumb {
        -webkit-appearance: none; width: 18px; height: 18px;
        border-radius: 50%; background: var(--accent); cursor: pointer;
        box-shadow: 0 0 6px var(--accent-glow); border: 2px solid white;
    }
    .filter-price-value { color: var(--accent); font-weight: 700; }
    .filter-slider-labels { display: flex; justify-content: space-between; font-size: var(--font-size-xs); color: var(--text-muted); }
</style>
