@page "/admin/nuevo-producto"
@using Blazor_Respawn_Shop.Models
@using Blazor_Respawn_Shop.Services
@inject IProductoService ProductoService
@inject NavigationManager Navigation

<PageTitle>Agregar Nuevo Producto</PageTitle>

<div class="admin-layout" style="background-color: #121212; min-height: 100vh; padding: 2rem; color: white;">

    <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 2rem;">
        <h2 style="margin: 0; font-weight: bold;">🎮 Blazor_Respawn_Shop <span style="color: var(--primary-blue); font-size: 1rem;">Admin</span></h2>
    </div>

    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 1.5rem;">AGREGAR NUEVO PRODUCTO</h1>

    <div style="display: flex; justify-content: center; align-items: center; gap: 10px; margin-bottom: 2rem;">
        <span style="font-size: 0.9rem; color: #aaa;">Modo Manual</span>
        <label class="switch">
            <input type="checkbox" @bind="modoIAActivado">
            <span class="slider round"></span>
        </label>
        <span style="font-size: 0.9rem; font-weight: bold; color: @(modoIAActivado ? "var(--primary-blue)" : "#aaa")">Modo IA Inteligente</span>
    </div>

    @if (modoIAActivado)
    {
        <div style="display: flex; gap: 10px; margin-bottom: 20px; border: 1px solid var(--primary-blue); border-radius: 8px; padding: 10px; background: rgba(0, 123, 255, 0.05);">
            <input @bind="nombreBusquedaIA" class="form-control" placeholder="Nombre del Producto a buscar con IA..." style="flex: 1; background: transparent; border: none; color: white; outline: none;" />
            <button @onclick="AutocompletarConIA" disabled="@buscandoIA" style="background-color: var(--primary-blue); color: white; border: none; padding: 8px 20px; border-radius: 5px; cursor: pointer; font-weight: bold;">
                @if (buscandoIA)
                {
                    <span>Buscando...</span>
                }
                else
                {

                    <span>Autocompletar</span>
                }
            </button>
        </div>
    }

    <EditForm Model="nuevoProducto" OnValidSubmit="GuardarProducto">
        <DataAnnotationsValidator />

        <div class="panel-section">
            <div class="panel-header">Descripción</div>
            <div class="panel-body" style="display: flex; gap: 20px;">

                <div style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
                    <span style="font-size: 0.8rem; color: #aaa;">Vista Previa</span>
                    <div style="background: #1e1e1e; border: 1px dashed #444; border-radius: 8px; height: 150px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(nuevoProducto.ImagenPrincipal) && nuevoProducto.ImagenPrincipal != "images/placeholder.png")
                        {
                            <img src="@nuevoProducto.ImagenPrincipal" style="max-height: 100%; max-width: 100%; object-fit: contain;" />
                        }
                        else
                        {
                            <span style="font-size: 2rem; color: #555;">🖼️</span>
                        }
                    </div>
                    <InputText @bind-Value="urlImagenTemporal" placeholder="URL de la imagen" class="admin-input" />
                </div>

                <div style="flex: 2; display: flex; flex-direction: column; gap: 10px;">
                    <span style="font-size: 0.8rem; color: #aaa;">Descripción</span>
                    <InputTextArea @bind-Value="nuevoProducto.Descripcion" class="admin-input" style="flex: 1; min-height: 150px; resize: none;" />
                </div>

                <div style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
                    <span style="font-size: 0.8rem; color: #aaa;">Categoría</span>
                    <InputSelect @bind-Value="nuevoProducto.CategoriaId" class="admin-input">
                        <option value="1">Juegos</option>
                        <option value="2">Consolas</option>
                        <option value="3">Controles</option>
                        <option value="4">Funko Pops</option>
                    </InputSelect>
                </div>

                <div style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
                    <span style="font-size: 0.8rem; color: #aaa;">Género</span>
                    <InputText @bind-Value="nuevoProducto.Genero" class="admin-input" placeholder="Ej. Acción, Aventura..." />
                </div>
            </div>
        </div>

        <div class="panel-section" style="margin-top: 20px;">
            <div class="panel-header">Requisitos del Sistema (PC)</div>
            <div class="panel-body">
                <InputTextArea @bind-Value="nuevoProducto.RequisitosSistema" class="admin-input" style="width: 100%; min-height: 80px; resize: vertical;" placeholder="Ej. OS: Windows 10, Procesador: Intel i5, RAM: 8GB..." />
            </div>
        </div>

        <div style="display: flex; gap: 20px; margin-top: 20px;">
            <div class="panel-section" style="flex: 1;">
                <div class="panel-header">Precio</div>
                <div class="panel-body">
                    <div style="display: flex; align-items: center; background: #1e1e1e; border: 1px solid #333; border-radius: 5px; overflow: hidden;">
                        <InputNumber @bind-Value="nuevoProducto.Precio" class="admin-input" style="border: none; flex: 1;" />
                        <div style="background: var(--primary-blue); padding: 10px; display: flex; align-items: center; justify-content: center;">
                            💵
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel-section" style="flex: 1;">
                <div class="panel-header">Cantidad en Stock <span style="color: #ff4d4d; font-size: 0.8rem;">Requerido</span></div>
                <div class="panel-body">
                    <InputNumber @bind-Value="nuevoProducto.Stock" class="admin-input" />
                </div>
            </div>
        </div>

        <div style="margin-top: 30px; text-align: right;">
            <button type="submit" disabled="@guardando" style="background-color: var(--primary-blue); color: white; border: none; padding: 12px 40px; border-radius: 5px; font-weight: bold; font-size: 1.1rem; cursor: pointer;">
                @if (guardando)
                {
                    <span>Guardando en BD...</span>
                }
                else
                {

                    <span>Guardar Producto</span>
                }
            </button>
        </div>

    </EditForm>
</div>

@code {
    private ProductoDto nuevoProducto = new ProductoDto { CategoriaId = 1, Stock = 10, Precio = 1.00m };
    private string nombreBusquedaIA = "";
    private string urlImagenTemporal = "";
    private bool modoIAActivado = true;
    private bool buscandoIA = false;
    private bool guardando = false;

    // Conexión real con tu API de Inteligencia Artificial
    private async Task AutocompletarConIA()
    {
        if (string.IsNullOrWhiteSpace(nombreBusquedaIA)) return;

        buscandoIA = true;

        var productoIA = await ProductoService.AutocompletarProductoConIAAsync(nombreBusquedaIA);

        if (productoIA != null)
        {
            // Pasamos los datos del JSON al formulario
            nuevoProducto.Nombre = productoIA.Nombre ?? nombreBusquedaIA;
            nuevoProducto.Descripcion = productoIA.Descripcion;
            nuevoProducto.Precio = productoIA.PrecioSugerido;
            nuevoProducto.Genero = productoIA.Genero;
            nuevoProducto.EsDigital = productoIA.EsDigital;
            nuevoProducto.RequisitosSistema = productoIA.RequisitosSistema;

            // Forzamos la categoría a "Juegos" (ID 1) por defecto para los juegos de RAWG
            nuevoProducto.CategoriaId = 1;

            // Extraemos el primer link de la lista de imágenes sugeridas para la vista previa
            if (productoIA.ImagenesSugeridas != null && productoIA.ImagenesSugeridas.Any())
            {
                urlImagenTemporal = productoIA.ImagenesSugeridas.First();
            }
        }

        buscandoIA = false;
    }

    private async Task GuardarProducto()
    {
        guardando = true;

        // Si escribiste una URL manual en la caja, la agregamos a la lista antes de guardar
        if (!string.IsNullOrWhiteSpace(urlImagenTemporal) && (nuevoProducto.Imagenes == null || !nuevoProducto.Imagenes.Any()))
        {
            nuevoProducto.Imagenes = new List<ImagenProductoDto> { new ImagenProductoDto { Url = urlImagenTemporal, EsPrincipal = true } };
        }

        // Llamamos al método POST de tu API
        var exito = await ProductoService.CrearProductoAsync(nuevoProducto);

        if (exito)
        {
            // Si se guardó bien en la base de datos, te devuelve al catálogo
            Navigation.NavigateTo("/catalogo");
        }
        else
        {
            // Aquí podríamos mostrar un mensaje de error rojo si falla la base de datos
            guardando = false;
        }
    }
}

<style>
    .panel-section {
        border: 1px solid var(--primary-blue);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 15px;
    }

    .panel-header {
        background-color: var(--primary-blue);
        color: white;
        padding: 8px 15px;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .panel-body {
        background-color: transparent;
        padding: 15px;
        border: 1px solid #333;
        border-top: none;
    }

    .admin-input {
        width: 100%;
        background-color: #1e1e1e;
        border: 1px solid #333;
        color: white;
        padding: 10px;
        border-radius: 5px;
        outline: none;
    }

        .admin-input:focus {
            border-color: var(--primary-blue);
        }

    /* Toggle Switch CSS (Sacado del diseño) */
    .switch {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 20px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .4s;
        }

    input:checked + .slider {
        background-color: var(--primary-blue);
    }

        input:checked + .slider:before {
            transform: translateX(20px);
        }

    .slider.round {
        border-radius: 34px;
    }

        .slider.round:before {
            border-radius: 50%;
        }
</style>