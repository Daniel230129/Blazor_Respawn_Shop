@page "/admin/editar-producto/{Id:int}"
@attribute [Authorize(Roles = "Administrador")]
@inject Blazor_Respawn_Shop.Services.IProductoService ProductoService
@inject NavigationManager Nav

<PageTitle>Admin - Editar Producto Completo</PageTitle>

<div class="admin-wrapper">
    <div class="header-section">
        <div>
            <h2 class="title">✏️ EDITAR VIDEOJUEGO</h2>
            <p class="subtitle">Modifica la ficha técnica completa del producto #@Id</p>
        </div>
        <button type="button" class="btn-back-outline" @onclick="Volver">⬅️ Volver al Panel</button>
    </div>

    @if (cargando)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Descargando datos del servidor...</p>
        </div>
    }
    else if (producto == null)
    {
        <div class="alert-error">❌ No se pudo encontrar el producto.</div>
    }
    else
    {
        <EditForm Model="producto" OnValidSubmit="GuardarCambios">
            <DataAnnotationsValidator />

            <div class="grid-container">
                <div class="column">
                    <div class="admin-card">
                        <h3 class="card-title">🖼️ Multimedia</h3>

                        <div class="image-preview-box">
                            @if (!string.IsNullOrWhiteSpace(urlImagenTemp))
                            {
                                <img src="@urlImagenTemp" alt="Vista previa" class="preview-img" />
                            }
                            else
                            {
                                <div class="no-image">Sin Imagen</div>
                            }
                        </div>

                        <div class="form-group">
                            <label>URL de la imagen principal</label>
                            <InputText @bind-Value="urlImagenTemp" class="form-control" placeholder="https://..." />
                        </div>
                    </div>

                    <div class="admin-card">
                        <h3 class="card-title">💰 Inventario y Precio</h3>
                        <div class="grid-2-cols">
                            <div class="form-group">
                                <label>Precio ($)</label>
                                <InputNumber @bind-Value="producto.Precio" class="form-control" />
                            </div>
                            <div class="form-group">
                                <label>Stock</label>
                                <InputNumber @bind-Value="producto.Stock" class="form-control" />
                            </div>
                        </div>
                        <div class="checkbox-group">
                            <InputCheckbox @bind-Value="producto.EsDigital" id="esDigital" />
                            <label for="esDigital">Producto Digital (Envío por correo)</label>
                        </div>
                    </div>
                </div>

                <div class="column">
                    <div class="admin-card">
                        <h3 class="card-title">📝 Información General</h3>

                        <div class="form-group">
                            <label>Nombre del Producto</label>
                            <InputText @bind-Value="producto.Nombre" class="form-control" />
                        </div>

                        <div class="grid-2-cols">
                            <div class="form-group">
                                <label>Categoría</label>
                                <InputSelect @bind-Value="producto.CategoriaId" class="form-control">
                                    <option value="1">Juegos</option>
                                    <option value="2">Consolas</option>
                                    <option value="4">Funko Pops</option>
                                    <option value="5">Accesorios o Perifericos</option>
                                </InputSelect>
                            </div>
                            <div class="form-group">
                                <label>Género</label>
                                <InputText @bind-Value="producto.Genero" class="form-control" placeholder="Ej. Acción, RPG..." />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Descripción Completa</label>
                            <InputTextArea @bind-Value="producto.Descripcion" class="form-control" rows="5" />
                        </div>
                    </div>

                    <div class="admin-card">
                        <h3 class="card-title">⚙️ Requisitos del Sistema (PC)</h3>
                        <div class="form-group">
                            <InputTextArea @bind-Value="producto.RequisitosSistema" class="form-control" rows="3" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="action-footer">
                <button type="button" class="btn-cancel" @onclick="Volver">Cancelar Cambios</button>
                <button type="submit" class="btn-save">💾 Guardar Producto</button>
            </div>
        </EditForm>
    }
</div>

<style>
    .admin-wrapper {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        border-bottom: 1px solid #333;
        padding-bottom: 1rem;
    }

    .title {
        font-weight: 800;
        margin: 0;
        color: #007bff;
        font-size: 1.8rem;
    }

    .subtitle {
        color: #aaa;
        margin: 5px 0 0 0;
    }

    .grid-container {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 20px;
        margin-bottom: 2rem;
    }

    @@media (max-width: 900px) {
        .grid-container {
            grid-template-columns: 1fr;
        }
    }

    .column {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .admin-card {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .card-title {
        margin-top: 0;
        border-bottom: 1px solid #333;
        padding-bottom: 10px;
        margin-bottom: 15px;
        font-size: 1.1rem;
        color: #e0e0e0;
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #aaa;
            font-size: 0.9rem;
            font-weight: bold;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background: #0f0f0f;
        border: 1px solid #444;
        border-radius: 8px;
        color: white;
        transition: border-color 0.3s;
    }

        .form-control:focus {
            border-color: #007bff;
            outline: none;
        }

    .grid-2-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .image-preview-box {
        width: 100%;
        height: 250px;
        background: #0f0f0f;
        border: 1px dashed #444;
        border-radius: 8px;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .preview-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .no-image {
        color: #555;
        font-style: italic;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
        padding: 10px;
        background: #0f0f0f;
        border-radius: 8px;
        border: 1px solid #333;
    }

        .checkbox-group input {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .checkbox-group label {
            color: #ccc;
            cursor: pointer;
            user-select: none;
            margin: 0;
        }

    .action-footer {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        border-top: 1px solid #333;
        padding-top: 20px;
    }

    .btn-save {
        padding: 12px 30px;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        font-size: 1rem;
    }

        .btn-save:hover {
            background: #0056b3;
            transform: translateY(-2px);
        }

    .btn-cancel {
        padding: 12px 20px;
        background: transparent;
        color: #aaa;
        border: 1px solid #555;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            background: #333;
            color: white;
        }

    .btn-back-outline {
        padding: 8px 15px;
        background: transparent;
        color: #007bff;
        border: 1px solid #007bff;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
    }

        .btn-back-outline:hover {
            background: rgba(0, 123, 255, 0.1);
        }

    .loading-state {
        text-align: center;
        padding: 3rem;
    }

    .alert-error {
        background: rgba(255,77,77,0.1);
        border: 1px solid #ff4d4d;
        padding: 15px;
        border-radius: 8px;
        color: #ff4d4d;
        text-align: center;
        margin-top: 2rem;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private Blazor_Respawn_Shop.Models.ProductoDto? producto;
    private bool cargando = true;

    private string urlImagenTemp = "";

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;
            producto = await ProductoService.GetProductoByIdAsync(Id);

            if (producto != null)
            {
                urlImagenTemp = producto.Imagenes?.FirstOrDefault(i => i.EsPrincipal)?.Url
                                ?? producto.Imagenes?.FirstOrDefault()?.Url ?? "";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar producto: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task GuardarCambios()
    {
        if (producto == null) return;

        if (!string.IsNullOrWhiteSpace(urlImagenTemp))
        {
            producto.Imagenes = new List<Blazor_Respawn_Shop.Models.ImagenProductoDto>
            {
                new Blazor_Respawn_Shop.Models.ImagenProductoDto { Url = urlImagenTemp, EsPrincipal = true }
            };
        }

        var exito = await ProductoService.ActualizarProductoAsync(Id, producto);
        if (exito) Volver();
    }

    private void Volver()
    {
        Nav.NavigateTo("/admin/productos");
    }
}