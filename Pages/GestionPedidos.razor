@page "/admin/pedidos"
@attribute [Authorize(Roles = "Administrador")]
@inject Blazor_Respawn_Shop.Services.PedidoService PedidoService
@inject NavigationManager Nav

<PageTitle>Admin - Control de Pedidos</PageTitle>

<div class="admin-wrapper">
    <div class="header-section">
        <div>
            <h2 class="title">📦 CONTROL DE PEDIDOS</h2>
            <p class="subtitle">Gestiona las compras de los clientes y actualiza sus estados</p>
        </div>
    </div>

    @if (cargando)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando historial de transacciones...</p>
        </div>
    }
    else if (!pedidos.Any())
    {
        <div class="alert-info">No hay pedidos registrados en la tienda todavía.</div>
    }
    else
    {
        <div class="admin-card" style="padding: 0; overflow: hidden;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Nº ORDEN</th>
                        <th>FECHA</th>
                        <th>ID CLIENTE</th>
                        <th>TOTAL</th>
                        <th>ESTADO ACTUAL</th>
                        <th style="text-align: center;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in pedidos.OrderByDescending(p => p.FechaPedido))
                    {
                        <tr>
                            <td style="font-weight: bold; color: #aaa;">#@pedido.Id.ToString("D4")</td>
                            <td>@pedido.FechaPedido.ToString("dd MMM yyyy, HH:mm")</td>
                            <td>Usuario @pedido.UsuarioId</td>
                            <td style="color: #00ce7a; font-weight: bold;">$@pedido.TotalPagado.ToString("0.00")</td>
                            <td>
                                <select value="@pedido.Estado" @onchange="@(e => CambiarEstado(pedido.Id, e))">
                                    <option value="Pendiente">🟡 Pendiente</option>
                                    <option value="Procesando">🔵 Procesando</option>
                                    <option value="Completado">🟢 Completado</option>
                                    <option value="Cancelado">🔴 Cancelado</option>
                                </select>
                            </td>
                            <td style="text-align: center;">
                                <button class="btn-action" title="Ver detalles del pedido" @onclick="() => VerDetalles(pedido.Id)">👁️ Detalles</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    /* Estilos base consistentes con tu diseño premium */
    .admin-wrapper {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        border-bottom: 1px solid #333;
        padding-bottom: 1rem;
    }

    .title {
        font-weight: 800;
        margin: 0;
        color: #007bff;
        font-size: 1.8rem;
    }

    .subtitle {
        color: #aaa;
        margin: 5px 0 0 0;
    }

    .admin-card {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .admin-table th {
            background: #222;
            color: #007bff;
            padding: 15px;
            font-size: 0.9rem;
            border-bottom: 1px solid #333;
        }

        .admin-table td {
            padding: 15px;
            border-bottom: 1px solid #2a2a2a;
            color: #e0e0e0;
            vertical-align: middle;
        }

        .admin-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    /* Selector de estado interactivo */
    .status-select {
        background: #0f0f0f;
        color: white;
        border: 1px solid #444;
        padding: 6px 10px;
        border-radius: 6px;
        cursor: pointer;
        outline: none;
        font-weight: bold;
        width: 140px;
    }

        .status-select:focus {
            border-color: #007bff;
        }

    /* Colores dinámicos para los estados */
    .estado-pendiente {
        border-left: 3px solid #ffc107;
    }

    .estado-procesando {
        border-left: 3px solid #007bff;
    }

    .estado-completado {
        border-left: 3px solid #00ce7a;
    }

    .estado-cancelado {
        border-left: 3px solid #ff4d4d;
        color: #ff4d4d;
    }

    .btn-action {
        background: #2a2a2a;
        border: 1px solid #444;
        border-radius: 6px;
        padding: 8px 12px;
        color: white;
        cursor: pointer;
        transition: 0.2s;
        font-size: 0.9rem;
    }

        .btn-action:hover {
            background: rgba(0, 123, 255, 0.2);
            border-color: #007bff;
        }

    .loading-state {
        text-align: center;
        padding: 3rem;
    }

    .alert-info {
        background: rgba(0, 123, 255, 0.1);
        border: 1px solid #007bff;
        padding: 20px;
        border-radius: 8px;
        color: #66b2ff;
        text-align: center;
    }
</style>

@code {
    private List<Blazor_Respawn_Shop.Models.PedidoDto> pedidos = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cargando = true;
            // Recordando que este endpoint de tu compañero devuelve TODOS los pedidos de la base de datos
            var lista = await PedidoService.GetMisPedidosAsync();
            pedidos = lista.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar pedidos: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private string ObtenerClaseEstado(string estado)
    {
        return estado?.ToLower() switch
        {
            "completado" => "estado-completado",
            "procesando" => "estado-procesando",
            "cancelado" => "estado-cancelado",
            _ => "estado-pendiente"
        };
    }

    private async Task CambiarEstado(int pedidoId, ChangeEventArgs e)
    {
        string nuevoEstado = e.Value?.ToString() ?? "Pendiente";
        Console.WriteLine($"[DEBUG] Cambiando pedido {pedidoId} a estado: {nuevoEstado}");

        // ¡ESTA ES LA LÍNEA MÁGICA QUE FALTA PARA GUARDAR EN LA BASE DE DATOS!
        var exito = await PedidoService.ActualizarEstadoAsync(pedidoId, nuevoEstado);

        if (exito)
        {
            Console.WriteLine("¡Estado guardado exitosamente en la base de datos!");
        }
        else
        {
            Console.WriteLine("❌ Error: No se pudo guardar en la API.");
        }
    }

    private void VerDetalles(int id)
    {
        Nav.NavigateTo($"/pedido/{id}");
    }
}