@page "/admin/pedidos"
@attribute [Authorize(Roles = "Administrador")]
@inject Blazor_Respawn_Shop.Services.PedidoService PedidoService
@inject NavigationManager Nav

<PageTitle>Admin - Control de Pedidos</PageTitle>

<div class="admin-wrapper">
    <div class="header-section">
        <div>
            <h2 class="title">📦 CONTROL DE PEDIDOS</h2>
            <p class="subtitle">Gestiona las compras de los clientes y actualiza sus estados</p>
        </div>
    </div>

    @if (cargando)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando historial de transacciones...</p>
        </div>
    }
    else if (!pedidos.Any())
    {
        <div class="alert-info">No hay pedidos registrados en la tienda todavía.</div>
    }
    else
    {
        <div class="admin-card" style="padding: 0; overflow: hidden;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Nº ORDEN</th>
                        <th>FECHA</th>
                        <th>CLIENTE</th>
                        <th>TOTAL</th>
                        <th>ESTADO ACTUAL</th>
                        <th style="text-align: center;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in pedidos.OrderByDescending(p => p.FechaPedido))
                    {
                        <tr>
                            <td style="font-weight: bold; color: #aaa;">#@pedido.Id.ToString("D4")</td>
                            <td>@pedido.FechaPedido.ToString("dd MMM yyyy, HH:mm")</td>
                            <td style="font-weight: 500;">
                                @(pedido.Usuario?.Nombre ?? $"Cliente #{pedido.UsuarioId}")
                            </td>
                            <td style="color: #00ce7a; font-weight: bold;">$@pedido.TotalPagado.ToString("0.00")</td>
                            <td>
                                <select class="status-select" value="@pedido.Estado" @onchange="@(e => CambiarEstado(pedido.Id, e))">
                                    <option value="Pendiente">🟡 Pendiente</option>
                                    <option value="Procesando">🔵 Procesando</option>
                                    <option value="Completado">🟢 Completado</option>
                                    <option value="Cancelado">🔴 Cancelado</option>
                                </select>
                            </td>
                            <td style="text-align: center;">
                                <button class="btn-action" title="Ver detalles del pedido" @onclick="() => VerDetalles(pedido.Id)">👁️ Detalles</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    /* Estilos base consistentes con tu diseño premium */
    .admin-wrapper {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        border-bottom: 1px solid #333;
        padding-bottom: 1rem;
    }

    .title {
        font-weight: 800;
        margin: 0;
        color: #007bff;
        font-size: 1.8rem;
    }

    .subtitle {
        color: #aaa;
        margin: 5px 0 0 0;
    }

    .admin-card {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .admin-table th {
            background: #222;
            color: #007bff;
            padding: 15px;
            font-size: 0.9rem;
            border-bottom: 1px solid #333;
        }

        .admin-table td {
            padding: 15px;
            border-bottom: 1px solid #2a2a2a;
            color: #e0e0e0;
            vertical-align: middle;
        }

        .admin-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    .status-select {
        background: #121212;
        color: white;
        border: 1px solid #444;
        /* Aumentamos el padding derecho a 32px para hacerle espacio a la flecha */
        padding: 8px 32px 8px 12px;
        border-radius: 6px;
        cursor: pointer;
        outline: none;
        font-weight: bold;
        /* Aumentamos el ancho para que la palabra "Completado" quepa perfecta */
        width: 175px;
        transition: all 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23007bff%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
        background-repeat: no-repeat;
        /* Movemos la flechita un poco más al borde derecho */
        background-position: right 12px top 50%;
        background-size: 10px auto;
    }

        .status-select:focus, .status-select:hover {
            border-color: #007bff;
            box-shadow: 0 0 5px rgba(0, 123, 255, 0.2);
        }

        .status-select option {
            background-color: #1e1e1e;
            color: #fff;
            padding: 10px;
        }

    /* Colores dinámicos para los estados */
    .estado-pendiente {
        border-left: 3px solid #ffc107;
    }

    .estado-procesando {
        border-left: 3px solid #007bff;
    }

    .estado-completado {
        border-left: 3px solid #00ce7a;
    }

    .estado-cancelado {
        border-left: 3px solid #ff4d4d;
        color: #ff4d4d;
    }

    /* Botón de acciones Premium */
    .btn-action {
        background: transparent;
        border: 1px solid #444;
        border-radius: 6px;
        padding: 6px 14px;
        color: #aaa;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-action:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: #007bff;
            color: #fff;
        }

    .loading-state {
        text-align: center;
        padding: 3rem;
    }

    .alert-info {
        background: rgba(0, 123, 255, 0.1);
        border: 1px solid #007bff;
        padding: 20px;
        border-radius: 8px;
        color: #66b2ff;
        text-align: center;
    }
</style>

@code {
    private List<Blazor_Respawn_Shop.Models.PedidoDto> pedidos = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cargando = true;
            // Recordando que este endpoint de tu compañero devuelve TODOS los pedidos de la base de datos
            var lista = await PedidoService.GetMisPedidosAsync();
            pedidos = lista.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar pedidos: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private string ObtenerClaseEstado(string estado)
    {
        return estado?.ToLower() switch
        {
            "completado" => "estado-completado",
            "procesando" => "estado-procesando",
            "cancelado" => "estado-cancelado",
            _ => "estado-pendiente"
        };
    }

    private async Task CambiarEstado(int pedidoId, ChangeEventArgs e)
    {
        string nuevoEstado = e.Value?.ToString() ?? "Pendiente";
        Console.WriteLine($"[DEBUG] Cambiando pedido {pedidoId} a estado: {nuevoEstado}");

        // ¡ESTA ES LA LÍNEA MÁGICA QUE FALTA PARA GUARDAR EN LA BASE DE DATOS!
        var exito = await PedidoService.ActualizarEstadoAsync(pedidoId, nuevoEstado);

        if (exito)
        {
            Console.WriteLine("¡Estado guardado exitosamente en la base de datos!");
        }
        else
        {
            Console.WriteLine("❌ Error: No se pudo guardar en la API.");
        }
    }

    private void VerDetalles(int id)
    {
        Nav.NavigateTo($"/pedido/{id}");
    }
}