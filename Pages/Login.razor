@page "/login"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Blazor_Respawn_Shop.Services.LocalStorageService LocalStorage
@inject IConfiguration Config

<PageTitle>Iniciar Sesión | Blazor_Respawn_Shop</PageTitle>

<div class="login-page-wrapper">
    <div class="login-card">
        <div class="login-header">
            <span class="login-icon">🎮</span>
            <h2>INICIAR SESIÓN</h2>
            <p>Ingresa a tu cuenta para gestionar tus juegos y compras</p>
        </div>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="error-alert">
                ⚠️ @mensajeError
            </div>
        }

        <EditForm Model="loginModel" OnValidSubmit="ManejarLogin">
            <div class="form-group">
                <label>Correo Electrónico</label>
                <input type="email" @bind-value="loginModel.Correo" placeholder="ejemplo@correo.com" required autocomplete="email" />
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" @bind-value="loginModel.Password" placeholder="••••••••" required autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-login" disabled="@cargando">
                @if (cargando)
                {
                    <span>⏳ Procesando...</span>
                }
                else
                {
                    <span>ENTRAR A LA TIENDA</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <p>¿No tienes una cuenta? <a href="/registrar">Regístrate aquí</a></p>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private bool cargando = false;
    private string mensajeError = string.Empty;

    private async Task ManejarLogin()
    {
        cargando = true;
        mensajeError = string.Empty;

        try
        {
            var urlBase = Config["ApiSettings:BaseUrl"];

            var urlFinal = $"{urlBase}Usuarios/login";

            // 3. Hacemos la petición
            var respuesta = await Http.PostAsJsonAsync(urlFinal, loginModel);

            if (respuesta.IsSuccessStatusCode)
            {
                var resultado = await respuesta.Content.ReadFromJsonAsync<LoginResult>();

                if (resultado != null && !string.IsNullOrEmpty(resultado.Token))
                {
                    await LocalStorage.SetItemAsync("authToken", resultado.Token);
                    Navigation.NavigateTo("/catalogo", forceLoad: true);
                }
            }
            else
            {
                mensajeError = "Correo o contraseña incorrectos. Inténtalo de nuevo.";
            }
        }
        catch (Exception)
        {
            mensajeError = "No se pudo conectar con el servidor. Asegúrate de que la API esté corriendo.";
        }
        finally
        {
            cargando = false;
        }
    }   

    public class LoginRequest
    {
        public string Correo { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    public class LoginResult
    {
        public string Token { get; set; } = string.Empty;
    }
}

