@page "/carrito"
@inject Blazor_Respawn_Shop.Services.CartService CartService
@implements IDisposable

<PageTitle>Tu Carrito | Blazor_Respawn_Shop</PageTitle>

<div class="cart-page-container">
    <div class="cart-grid">

        <div class="cart-items-panel">
            <h3 class="panel-title">TU CARRITO</h3>

            <div class="items-container">
                @if (!CartService.Items.Any())
                {
                    <div class="empty-cart" style="padding: 3rem 1rem; text-align: center;">
                        <p style="margin-bottom: 1rem; color: #aaa;">No tienes juegos en tu carrito aún.</p>
                        <a href="/catalogo" class="btn-proceder" style="text-decoration: none; display: inline-block; width: auto; padding: 10px 20px;">Volver al Catálogo</a>
                    </div>
                }
                else
                {
                    @foreach (var item in CartService.Items)
                    {
                        <div class="cart-item">
                            <div class="item-info">
                                <img src="@item.Producto.ImagenPrincipal" alt="@item.Producto.Nombre" class="item-img" />
                                <div class="item-details">
                                    <h4 class="item-name">@item.Producto.Nombre</h4>
                                    <span class="item-platform">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 4px;">
                                            <path d="M13.5 3a.5.5 0 0 1 .5.5V11H2V3.5a.5.5 0 0 1 .5-.5h11zm-11-1A1.5 1.5 0 0 0 1 3.5V12h14V3.5A1.5 1.5 0 0 0 13.5 2h-11zM0 12.5h16a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 12.5z" />
                                        </svg>
                                        @(item.Producto.EsDigital ? "PC" : "Consola")
                                    </span>
                                </div>
                            </div>

                            <div class="item-quantity-wrapper">
                                <span class="qty-label">Cantidad</span>
                                <div class="qty-controls">
                                    <button class="qty-btn" @onclick="() => Restar(item.Producto.Id)">-</button>
                                    <input type="text" value="@item.Cantidad" readonly class="qty-input" />
                                    <button class="qty-btn" @onclick="() => Sumar(item.Producto)">+</button>
                                </div>
                            </div>

                            <div class="item-price-wrapper">
                                <span class="discount-badge">-10% OFF</span>
                                <span class="price-text">S/ @item.Subtotal.ToString("F2")</span>
                            </div>

                            <button class="btn-eliminar" @onclick="() => Eliminar(item.Producto.Id)">Eliminar</button>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="cart-summary-panel">
            <h3 class="panel-title">RESUMEN DEL PEDIDO</h3>

            <div class="summary-box">
                <div class="summary-row">
                    <span>Subtotal:</span>
                    <span>S/ @CartService.TotalCarrito.ToString("F2")</span>
                </div>
                <div class="summary-row discount-row">
                    <span>Descuento:</span>
                    <span>- S/ 0.00</span>
                </div>
                <div class="summary-row">
                    <span>Envío:</span>
                    <span>Gratis</span>
                </div>

                <div class="summary-divider"></div>

                <div class="summary-row total-row">
                    <span>TOTAL:</span>
                    <span>S/ @CartService.TotalCarrito.ToString("F2")</span>
                </div>

                <button class="btn-proceder">PROCEDER AL PAGO</button>

                <div class="payment-methods">
                    <div class="payment-icon">PayPal</div>
                    <div class="payment-icon">VISA</div>
                    <div class="payment-icon">MasterCard</div>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Nos suscribimos para que la pantalla se actualice al sumar o restar
        CartService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }

    private void Sumar(Blazor_Respawn_Shop.Models.ProductoDto producto)
    {
        CartService.AñadirAlCarrito(producto);
    }

    private void Restar(int id)
    {
        CartService.RestarDelCarrito(id);
    }

    private void Eliminar(int id)
    {
        CartService.EliminarTotalmente(id);
    }
}

<style>
    :root {
        --bg-dark: #121212;
        --panel-bg: #1e1e1e;
        --border-color: #333;
        --text-main: #ffffff;
        --text-muted: #aaaaaa;
        --blue-btn: #007bff;
        --blue-badge: #0d6efd;
    }

    .cart-page-container {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        color: var(--text-main);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .cart-grid {
        display: flex;
        gap: 2rem;
        align-items: flex-start;
    }

    .cart-items-panel {
        flex: 2;
    }

    .cart-summary-panel {
        flex: 1;
        min-width: 300px;
    }

    .panel-title {
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 1px;
        margin-bottom: 1.5rem;
        color: var(--text-main);
    }

    .items-container {
        background-color: var(--panel-bg);
        border-radius: 12px;
        padding: 0 1.5rem;
    }

    .cart-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--border-color);
    }

        .cart-item:last-child {
            border-bottom: none;
        }

    .item-info {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 2;
    }

    .item-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 8px;
    }

    .item-name {
        margin: 0 0 5px 0;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .item-platform {
        font-size: 0.85rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
    }

    .item-quantity-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        flex: 1;
    }

    .qty-label {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .qty-controls {
        display: flex;
        background-color: #2a2a2a;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

    .qty-btn {
        background: transparent;
        border: none;
        color: var(--text-main);
        padding: 4px 12px;
        cursor: pointer;
        font-size: 1.1rem;
    }

        .qty-btn:hover {
            background-color: #333;
        }

    .qty-input {
        width: 35px;
        text-align: center;
        background-color: #1a1a1a;
        border: none;
        color: var(--text-main);
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
        font-weight: bold;
    }

    .item-price-wrapper {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 5px;
        flex: 1;
    }

    .discount-badge {
        background-color: var(--blue-badge);
        color: white;
        font-size: 0.75rem;
        font-weight: bold;
        padding: 3px 8px;
        border-radius: 4px;
    }

    .price-text {
        font-size: 1.1rem;
        font-weight: bold;
    }

    .btn-eliminar {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 8px 15px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: 0.2s;
        margin-left: 1rem;
    }

        .btn-eliminar:hover {
            background-color: #ff4d4d;
            color: white;
            border-color: #ff4d4d;
        }

    .summary-box {
        background-color: var(--panel-bg);
        border-radius: 12px;
        padding: 2rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        color: var(--text-muted);
        font-size: 1rem;
    }

    .discount-row {
        color: var(--blue-btn);
    }

    .summary-divider {
        height: 1px;
        background-color: var(--border-color);
        margin: 1.5rem 0;
    }

    .total-row {
        color: var(--text-main);
        font-size: 1.4rem;
        font-weight: bold;
        margin-bottom: 2rem;
    }

    .btn-proceder {
        width: 100%;
        background-color: var(--blue-btn);
        color: white;
        border: none;
        padding: 15px;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.3s;
    }

        .btn-proceder:hover {
            background-color: #0056b3;
        }

    .payment-methods {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 1.5rem;
    }

    .payment-icon {
        background-color: white;
        color: black;
        font-size: 0.7rem;
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 4px;
    }
</style>