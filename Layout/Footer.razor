                    <a href="#" class="social-btn" id="footer-instagram" aria-label="Instagram" title="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                        </svg>
                    </a>
                    <a href="#" class="social-btn" id="footer-youtube" aria-label="YouTube" title="YouTube">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Columna 2: Categorías -->
            <div class="footer-column">
                <h4 class="footer-col-title">Categorías</h4>
                <ul class="footer-links">
                    <li><a href="/catalogo" id="footer-juegos">🎮 Videojuegos</a></li>
                    <li><a href="/catalogo" id="footer-consolas">🕹️ Consolas</a></li>
                    <li><a href="/catalogo" id="footer-controles">🎯 Controles</a></li>
                    <li><a href="/catalogo" id="footer-funkos">🧸 Funko Pops</a></li>
                    <li><a href="/catalogo" id="footer-accesorios">⚡ Accesorios</a></li>
                </ul>
            </div>

            <!-- Columna 3: Soporte -->
            <div class="footer-column">
                <h4 class="footer-col-title">Soporte</h4>
                <ul class="footer-links">
                    <li><a href="#" id="footer-faq">Centro de Ayuda</a></li>
                    <li><a href="#" id="footer-tracking">Seguir Pedido</a></li>
                    <li><a href="#" id="footer-returns">Devoluciones</a></li>
                    <li><a href="#" id="footer-warranty">Garantía</a></li>
                    <li><a href="#" id="footer-contact">Contacto</a></li>
                </ul>
            </div>

            <!-- Columna 4: Newsletter -->
            <div class="footer-column">
                <h4 class="footer-col-title">Newsletter Gamer</h4>
                <p class="footer-newsletter-text">
                    Recibe las mejores ofertas y lanzamientos directamente en tu inbox.
                </p>
                <div class="footer-newsletter-form">
                    <input type="email" placeholder="tu@email.com"
                           class="newsletter-input" id="footer-email-input"
                           @bind="emailNewsletter" />
                    <button class="btn btn-primary btn-sm" id="footer-subscribe-btn"
                            @onclick="SuscribirNewsletter">
                        Suscribir
                    </button>
                </div>
                @if (suscritoOk)
                {
                    <p class="newsletter-success">✅ ¡Suscrito con éxito!</p>
                }
            </div>
        </div>

        <!-- Línea divisoria -->
        <div class="footer-divider"></div>

        <!-- Sección inferior: copyright y plataformas -->
        <div class="footer-bottom">
            <p class="footer-copyright">
                © @DateTime.Now.Year <strong>Respawn Shop</strong>. Todos los derechos reservados.
                Hecho con ❤️ para gamers.
            </p>
            <div class="footer-platforms">
                <span class="platform-tag">PS5</span>
                <span class="platform-tag">Xbox</span>
                <span class="platform-tag">Nintendo Switch</span>
                <span class="platform-tag">PC</span>
            </div>
        </div>
    </div>
</footer>

@code {
    // Estado del newsletter
    private string emailNewsletter = string.Empty;
    private bool suscritoOk = false;

    /// <summary>Simula la suscripción al newsletter.</summary>
    private void SuscribirNewsletter()
    {
        if (!string.IsNullOrWhiteSpace(emailNewsletter))
        {
            suscritoOk = true;
            emailNewsletter = string.Empty;
        }
    }
}

<style>
    .footer {
        background: #0a0a0a;
        border-top: 1px solid rgba(30, 144, 255, 0.15);
        padding: var(--space-16) 0 var(--space-8);
        margin-top: auto;
    }
    .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: var(--space-12);
        margin-bottom: var(--space-12);
    }
    .footer-logo {
        display: flex; align-items: center; gap: var(--space-2);
        text-decoration: none;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        font-size: var(--font-size-xl); font-weight: 800; margin-bottom: var(--space-4);
        color: var(--accent);
    }
    .footer-logo svg { fill: var(--accent); flex-shrink: 0; }
    .footer-description { color: var(--text-muted); font-size: var(--font-size-sm); line-height: 1.7; margin-bottom: var(--space-6); }
    .footer-social { display: flex; gap: var(--space-3); }
    .social-btn {
        display: flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; background: rgba(255,255,255,0.06);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-md);
        color: var(--text-muted); transition: all var(--transition-base);
        text-decoration: none;
    }
    .social-btn:hover { color: var(--accent); border-color: var(--accent); background: var(--accent-glow); }
    .footer-col-title {
        font-size: var(--font-size-sm); font-weight: 700; color: var(--text-primary);
        text-transform: uppercase; letter-spacing: 1px; margin-bottom: var(--space-4);
    }
    .footer-links { display: flex; flex-direction: column; gap: var(--space-3); }
    .footer-links a { color: var(--text-muted); font-size: var(--font-size-sm); text-decoration: none; transition: color var(--transition-fast); }
    .footer-links a:hover { color: var(--accent); }
    .footer-newsletter-text { color: var(--text-muted); font-size: var(--font-size-sm); margin-bottom: var(--space-4); }
    .footer-newsletter-form { display: flex; gap: var(--space-2); }
    .newsletter-input {
        flex: 1; padding: var(--space-2) var(--space-3); background: var(--bg-secondary);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-md);
        color: var(--text-primary); font-size: var(--font-size-sm);
        font-family: var(--font-base); outline: none; transition: border-color var(--transition-fast);
    }
    .newsletter-input:focus { border-color: var(--accent); }
    .newsletter-success { color: var(--success); font-size: var(--font-size-xs); margin-top: var(--space-2); }
    .footer-divider { height: 1px; background: var(--border-subtle); margin-bottom: var(--space-6); }
    .footer-bottom { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-4); }
    .footer-copyright { color: var(--text-muted); font-size: var(--font-size-xs); }
    .footer-copyright strong { color: var(--accent); }
    .footer-platforms { display: flex; gap: var(--space-2); flex-wrap: wrap; }
    .platform-tag {
        padding: 2px var(--space-3); background: rgba(30,144,255,0.1);
        border: 1px solid rgba(30,144,255,0.2); border-radius: var(--radius-full);
        color: var(--text-secondary); font-size: var(--font-size-xs); font-weight: 600;
    }
    @@media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--space-8); } }
    @@media (max-width: 600px) {
        .footer-grid { grid-template-columns: 1fr; gap: var(--space-6); }
        .footer-bottom { flex-direction: column; align-items: flex-start; }
    }
</style>
