<!-- Footer de Blazor_Respawn_Shop -->
<footer class="footer" id="site-footer">
    <div class="container">

        <!-- Sección superior del footer -->
        <div class="footer-grid">

            <!-- Columna 1: Logo y descripción -->
            <div class="footer-brand">
                <a href="/" class="footer-logo" id="footer-logo-link">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                        <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 8 19.5 8s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
