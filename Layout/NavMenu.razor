@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav
@inject Blazor_Respawn_Shop.Services.CartService CartService
@implements IDisposable

<nav class="navbar" id="main-navbar">
    <div class="container navbar-inner">

        <a href="/" class="navbar-logo" id="navbar-logo-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                 class="logo-icon" width="28" height="28">
                <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 8 19.5 8s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" />
            </svg>
            <span class="logo-text">Blazor_Respawn_Shop</span>
        </a>

        <ul class="navbar-links" id="navbar-links">
            <li>
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-link" id="nav-home">
                    Tendencias
                </NavLink>
            </li>
            <li>
                <NavLink href="/catalogo" class="nav-link" id="nav-catalogo">
                    Catalogo
                </NavLink>
            </li>
            <li>
                <a href="/catalogo" class="nav-link" id="nav-proximos">Próximos</a>
            </li>
            <li>
                <a href="#" class="nav-link" id="nav-blog">Blog</a>
            </li>
            <li>
                <a href="#" class="nav-link nav-link-support" id="nav-soporte">
                    <span class="support-dot"></span>
                    Soporte 24/7
                </a>
            </li>
        </ul>

        <div class="navbar-actions">
            <button class="nav-icon-btn" title="Buscar" id="btn-search" aria-label="Buscar productos">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                </svg>
            </button>

            <a href="/carrito" class="nav-icon-btn nav-cart-btn" title="Carrito" id="btn-cart" aria-label="Ver carrito" style="text-decoration: none; color: inherit; display: inline-flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96C5 16.1 6.9 18 9 18h12v-2H9.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63H19c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 23.46 5H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" />
                </svg>
                <span class="cart-badge">@CartService.ContadorProductos</span>
            </a>

            <a href="/login" class="nav-icon-btn" title="Iniciar Sesión" id="btn-user" aria-label="Mi cuenta" style="text-decoration: none; color: inherit; display: inline-flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                </svg>
            </a>

            <button class="navbar-hamburger" id="btn-hamburger" aria-label="Menú" @onclick="ToggleMenu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
        </div>
    </div>

    @if (menuOpen)
    {
        <div class="navbar-mobile-menu animate-fade-in" id="mobile-menu">
            <a href="/" class="mobile-nav-link" @onclick="CloseMenu" id="mobile-home">Tendencias</a>
            <a href="/catalogo" class="mobile-nav-link" @onclick="CloseMenu" id="mobile-catalogo">Preventas</a>
            <a href="/catalogo" class="mobile-nav-link" @onclick="CloseMenu" id="mobile-proximos">Próximos</a>
            <a href="#" class="mobile-nav-link" id="mobile-blog">Blog</a>
            <a href="#" class="mobile-nav-link mobile-support" id="mobile-soporte">
                <span class="support-dot"></span> Soporte 24/7
            </a>
        </div>
    }
</nav>

@code {
    private bool menuOpen = false;

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;

    protected override void OnInitialized()
    {
        CartService.OnChange += OnCartChanged;
    }

    private void OnCartChanged()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        CartService.OnChange -= OnCartChanged;
    }
}

<style>
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: rgba(13, 13, 13, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(30, 144, 255, 0.15);
        height: var(--navbar-height);
    }

    .navbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: var(--navbar-height);
        gap: var(--space-6);
    }

    .navbar-logo {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        text-decoration: none;
        flex-shrink: 0;
    }

    .logo-icon {
        color: var(--accent);
        filter: drop-shadow(0 0 8px var(--accent-glow));
    }

    .logo-text {
        font-size: var(--font-size-xl);
        font-weight: 800;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .navbar-links {
        display: flex;
        align-items: center;
        gap: var(--space-1);
        list-style: none;
        flex: 1;
        justify-content: center;
    }

    .nav-link {
        padding: var(--space-2) var(--space-3);
        color: var(--text-secondary);
        font-size: var(--font-size-sm);
        font-weight: 500;
        text-decoration: none;
        border-radius: var(--radius-md);
        transition: all var(--transition-base);
    }

        .nav-link:hover {
            color: var(--text-primary);
            background: rgba(30,144,255,0.1);
        }

        .nav-link.active {
            color: var(--accent);
            background: rgba(30,144,255,0.1);
        }

    .nav-link-support {
        display: flex;
        align-items: center;
        gap: var(--space-1);
        color: var(--success) !important;
    }

    .support-dot {
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
        flex-shrink: 0;
    }

    .navbar-actions {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        flex-shrink: 0;
    }

    .nav-icon-btn {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.06);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all var(--transition-base);
    }

        .nav-icon-btn:hover {
            color: var(--text-primary);
            background: rgba(30,144,255,0.15);
            border-color: var(--accent);
        }

    .cart-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        background: var(--accent);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 3px;
    }

    .navbar-hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: var(--space-2);
    }

    .hamburger-line {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--text-primary);
        border-radius: 2px;
    }

    .navbar-mobile-menu {
        position: absolute;
        top: var(--navbar-height);
        left: 0;
        right: 0;
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border-subtle);
        padding: var(--space-4);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .mobile-nav-link {
        padding: var(--space-3) var(--space-4);
        color: var(--text-secondary);
        font-size: var(--font-size-sm);
        font-weight: 500;
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: all var(--transition-base);
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }

        .mobile-nav-link:hover {
            color: var(--text-primary);
            background: rgba(30,144,255,0.1);
        }

    .mobile-support {
        color: var(--success) !important;
    }

    /* Aquí está la corrección con doble arroba */
    @@media (max-width: 900px) {
        .navbar-links {
            display: none;
        }

        .navbar-hamburger {
            display: flex;
        }
    }

    @@media (max-width: 480px) {
        .logo-text {
            font-size: var(--font-size-lg);
        }
    }
</style>